{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Node16",
    "jsx": "react",
    "strict": true,
    "moduleResolution": "node16",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
  },
  "include": [
    "src/**/*",
    "App.tsx"
  ],
  "extends": "expo/tsconfig.base"
}